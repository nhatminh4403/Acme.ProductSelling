
@{
    var title = ViewData["Title"].ToString();
    var titleAppName = L["Menu:AppName"].ToString();

    bool checkTitle = title.ToLower().Contains(titleAppName.ToLower());
    if(!checkTitle)
    {
        ViewData["Title"] = $"{title} - {titleAppName}";
    }
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"]</title>

    @* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous"> *@
    
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css">

  @*   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
          integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
          crossorigin="anonymous" referrerpolicy="no-referrer" /> *@

    <link href="~/lib/font-awesome/css/all.min.css" rel="stylesheet" />

    <link href="~/images/monitor.png" rel="shortcut icon" type="image/x-icon" />

    <abp-style-bundle name="@LeptonXLiteThemeBundles.Styles.Global" />
    <abp-style-bundle name="Main.Global" />
    <link href="~/css/shared/header.css" rel="stylesheet" />
    <link href="~/css/shared/chatbot.css" rel="stylesheet" />
    <script>
        // Run synchronously so the 'homepage' class is on <html> before first paint.
        // This prevents the category button from flashing on non-homepage pages.
        if (window.location.pathname === '/' || window.location.pathname === '') {
            document.documentElement.classList.add('homepage');
        }
    </script>

    @await RenderSectionAsync("styles", required: false)
    <style>
        /* Hide the category button on the homepage only — JS will reveal it after scrolling past the hero.
           On all other pages the button is rendered with show-on-scroll server-side and is always visible. */
        html.homepage #categoryMenuBtn,
        html.homepage #mobileCategoryBtn {
            visibility: hidden;
        }
    </style>
    <link href="~/css/shared/category-sidebar.css" rel="stylesheet" />
    <script>
        if (sessionStorage.getItem('appLoaded')) {
            document.documentElement.classList.add('app-loaded');
        }
    </script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: inherit;
            
        }
        html {
            font-size: 90%;
            line-height: 1.6rem;
            box-sizing: border-box;
        }
        .input-group .form-control:focus {
            box-shadow: none;
            border-color: transparent;
        }

        .modal {
            z-index: 10000 !important;
            overflow-y: auto !important;
        }

        .modal-backdrop {
            z-index: 9999 !important;
        }

        body.modal-open {
            overflow: auto !important;
            padding-right: 0 !important;
        }

        .modal-dialog {
            margin: 1.75rem auto;
        }

        .modal-body {
            max-height: 60vh;
            overflow-y: auto;
        }

        @@media (max-width: 576px) {
            .modal-dialog {
                margin: 1rem 0.5rem;
            }

            .modal-body {
                max-height: 50vh;
            }
        }
        /* app-loaded guard only needed on homepage — other pages have show-on-scroll server-rendered */
        html.homepage:not(.app-loaded) #categoryMenuBtn,
        html.homepage:not(.app-loaded) #mobileCategoryBtn {
            visibility: hidden;
        }
    </style>
</head>

<body class="abp-application-layout public-layout d-flex flex-column min-vh-100 preload" style="background: #f5f5f5f0">

    <!-- HEADER -->
    @await Component.InvokeAsync(typeof(Acme.ProductSelling.Web.Views.Shared.Components.Header.HeaderViewComponent))
   

    <div style="">
        @RenderBody()
    </div>

    <!-- FOOTER & MODAL -->
    @await Component.InvokeAsync(typeof(Acme.ProductSelling.Web.Views.Shared.Components.Footer.FooterViewComponent))
    @await Component.InvokeAsync(typeof(Acme.ProductSelling.Web.Views.Shared.Components.Modal.ModalViewComponent))

    @await Component.InvokeAsync(typeof(Acme.ProductSelling.Web.Views.Shared.Components.Chatbot.ChatWidgetViewComponent))

    <script src="~/libs/abp/core/abp.js"></script>
    <abp-script-bundle name="@LeptonXLiteThemeBundles.Scripts.Global" />
    <!-- The line above contains JQuery that has already been configured in Web Module. NO CHANGES NEEDED -->
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/lib/font-awesome/js/all.min.js" asp-append-version="true"></script>


    <script src="~/Abp/ServiceProxyScript" asp-append-version="true"></script>
    <script src="~/Abp/ApplicationLocalizationScript?cultureName=@CultureInfo.CurrentUICulture.Name"></script>
    <script src="~/Abp/ApplicationConfigurationScript" asp-append-version="true"></script>


    <abp-script-bundle name="Main.Global" />

    <script src="~/js/global-scripts/recently-viewed.js"></script>

    @await RenderSectionAsync("scripts", required: false)
    <script src="~/js/global/categorySidebar.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script src="~/js/shared/chatbot/chatbot-core.js"></script>
    <script src="~/js/shared/chatbot/chatbot-bubble.js"></script>
</body>
</html>