@using Acme.ProductSelling.Web.Themes.LeptonXLite.Components.Toolbar.LanguageSwitch

<footer class="bg-white text-dark  border-top footer">
    <div class="container" style="padding-top:10px">
        <!-- Upper section -->
        <div class="row justify-content-evenly text-center text-md-start" style="margin-top:10px">
            <!-- Cột 1 -->
            <div class="col-6 col-md-2 mb-4">
                <h6 class="fw-bold">@L["Footer:AboutUs"]</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:Introduction"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:Contact"]</a></li>
                </ul>
            </div>

            <!-- Cột 2 -->
            <div class="col-6 col-md-2 mb-4">
                <h6 class="fw-bold">@L["Footer:Policies"]</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:WarrantyPolicy"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:ShippingPolicy"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:PrivacyPolicy"]</a></li>
                </ul>
            </div>
            <!-- Cột 3 -->
            <div class="col-6 col-md-2 mb-4">
                <h6 class="fw-bold">@L["Footer:Information"]</h6>
                <ul class="list-unstyled">
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:StoreSystem"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:ShoppingGuide"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:PaymentGuide"]</a></li>
                    <li><a href="#" class="text-decoration-none text-dark">@L["Footer:BuildPC"]</a></li>
                </ul>
            </div>

            <!-- Cột 4 -->
            <div class="col-6 col-md-2 mb-4">
                <h6 class="fw-bold">
                    @L["Footer:SupportHotline"] <small class="text-muted d-block d-md-inline">(8:00 - 21:00)</small>
                </h6>
                <ul class="list-unstyled">
                    <li>@L["Footer:Warranty"] <a href="tel:19005325" class="text-primary">0123456789</a></li>
                    <li>@L["Footer:Complaints"] <a href="tel:18006173" class="text-primary">0123456789</a></li>
                    <li>Email: <a href="mailto:nhatminh4403@gmail.com" class="text-primary">nhatminh4403@gmail.com</a></li>
                </ul>
            </div>

            <!-- Cột 5: Cách thức thanh toán và Ngôn ngữ -->
            <div class="col-12 col-md-2 mb-4">
                <!-- Phần thanh toán -->
                <div class="mb-4">
                    <h6 class="fw-bold">@L["Footer:PaymentMethods"]</h6>
                    <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-start gap-2">
                        <img src="https://theme.hstatic.net/200000722513/1001090675/14/pay_1.png?v=8602" loading="lazy" alt="Internet Banking" width="50">
                        <img src="https://theme.hstatic.net/200000722513/1001090675/14/pay_5.png?v=8602" alt="Tiền mặt" loading="lazy" width="50">
                        <img src="https://theme.hstatic.net/200000722513/1001090675/14/pay_7.png?v=8602" alt="Visa" loading="lazy" width="50">
                        <img src="https://theme.hstatic.net/200000722513/1001090675/14/pay_8.png?v=8602" alt="Momo" loading="lazy" width="50">
                    </div>
                </div>

                <!-- Phần ngôn ngữ -->
                <div>
                    <h6 class="fw-bold">@L["Footer:Language"]</h6>
                    <div class="mt-3">
                        @await Component.InvokeAsync(typeof(LanguageSwitchViewComponent))
                    </div>
                </div>
            </div>

        </div>
        
    </div>
</footer>
