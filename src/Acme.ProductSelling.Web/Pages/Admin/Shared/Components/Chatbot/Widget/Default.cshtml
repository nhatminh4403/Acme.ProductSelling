@{

}

<div id="chatbotPageWidget" class="chatbot-page-widget">
    <div class="card shadow chatbot-card">

        <div class="card-header bg-primary text-white chatbot-card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fas fa-robot me-2"></i>
                @L["Chatbot:Title"]
            </h5>
            <div class="d-flex align-items-center gap-2">
                <span id="chatbotPageRoleBadge" class="badge bg-white text-primary">Guest</span>
                <button id="chatbotPageClearBtn"
                        class="btn btn-sm btn-outline-light"
                        title="@L["Chatbot:ClearHistory"]">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </div>
        </div>

        <div id="chatbotPageMessages" class="chatbot-card-body">
            <!-- Messages are injected by chatbot-page.js-->
        </div>

        <div class="card-footer chatbot-card-footer p-3">

            <!-- Quick-action chips-->
            <div class="mb-3 d-flex gap-2 overflow-auto" style="scrollbar-width:thin;">
                @if (CurrentUser.IsAuthenticated && (CurrentUser.IsInRole(IdentityRoleConsts.Admin) || CurrentUser.IsInRole(IdentityRoleConsts.Manager)))
                {
                <button class="btn btn-sm btn-outline-warning rounded-pill text-nowrap quick-question"
                        data-question="Sales Report">
                    <i class="fas fa-chart-bar me-1"></i>Sales Report
                </button>
                <button class="btn btn-sm btn-outline-warning rounded-pill text-nowrap quick-question"
                        data-question="Stock Status">
                    <i class="fas fa-boxes me-1"></i>Stock Check
                </button>
                }
            </div>

                <!-- Input row-->
                <form id="chatbotPageForm">
                    <div class="input-group">
                        <input type="text"
                               id="chatbotPageInput"
                               class="form-control border-end-0"
                               placeholder="..."
                               autocomplete="off"
                               required>
                        <button type="submit" class="btn btn-primary" id="chatbotPageSendBtn">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
