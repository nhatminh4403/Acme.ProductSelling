@page "/{prefix}"
@using Acme.ProductSelling.Localization
@using Microsoft.Extensions.Localization
@using Acme.ProductSelling.Categories
@using Newtonsoft.Json;
@using Acme.ProductSelling.Identity;
@using Acme.ProductSelling.Web.Pages.Admin.Shared.Components.Chatbot.Widget
@inject IStringLocalizer<ProductSellingResource> L
@inject Volo.Abp.Users.ICurrentUser CurrentUser
@inject IPageLayout PageLayoutMenu

@model Acme.ProductSelling.Web.Admin.Pages.IndexModel
@{
    var monthlyData = Json.Serialize(Model.MoneyStatisticsList);
    var allYearlyData = Json.Serialize(Model.YearlyStatistics);
    ViewData["Title"] = L["Admin:Menu:Home"];
    ViewData["IsChatWidgetOnly"] = true;


    Layout = "/Pages/Admin/Shared/_AdminLayout.cshtml";
}
@section scripts {

    <script src="~/js/admin/chart.js/Chart.bundle.min.js"> </script>
    <script>
        var monthlyStatistics = @Html.Raw(monthlyData);
        var allYearlyData = @Html.Raw(allYearlyData);
        var selectedYear = @Model.SelectedYear;

    </script>
    <script src="~/js/admin/main/chart-area-demo.js"></script>
    @* <script src="~/js/admin/Index.js"></script> *@

}

@section styles {
    <style>
        .border-left-primary {
            border-left: .25rem solid #4e73df !important;
        }

        .border-left-success {
            border-left: .25rem solid #1cc88a !important;
        }

        .border-left-danger {
            border-left: .25rem solid #e74a3b !important;
        }

        .border-left-warning {
            border-left: .25rem solid #f6c23e !important;
        }

        
        @@font-face {
            font-family: 'Nunito', sans-serif;
        }
    </style>
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    
    <link href="~/css/admin/main/sb-admin-2.min.css" rel="stylesheet">

}


<div class="container-fluid">
    @if (CurrentUser.IsInRole(IdentityRoleConsts.Admin))
    {
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-primary shadow h-100 py-2">
                    <div class="card-body p-0 py-1 px-3">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                    @L["Admin:Statistics:EarningsLastMonth"]
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalMoneyLastMonth VND</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-calendar fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-danger shadow h-100 py-2">
                    <div class="card-body p-0 py-1 px-3">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                    @L["Admin:Statistics:EarningsThisMonth"]
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalMoneyThisMonth VND</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-calendar fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow h-100 py-2">
                    <div class="card-body p-0 py-1 px-3">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    @L["Admin:Statistics:EarningsLastYear"]
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalMoneyLastYear VND</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-calendar fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow h-100 py-2">
                    <div class="card-body p-0 py-1 px-3">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    @L["Admin:Statistics:EarningsAnnual"]
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotatOrderPrice VND</div>
                            </div>
                            <div class="col-auto">
                                <i class="fa-solid fa-dong-sign fa-2x text-gray-300 fw-bold"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-xl-12 col-lg-12">
                <div class="card shadow mb-4">
                    <div class="card-header year-selector py-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <div class="mb-2 mb-md-0">
                            <h6 id="chartTitle" class="m-0 text-white font-weight-bold">
                                <i class="fas fa-chart-line mr-2"></i>
                                @L["Admin:Statistics:YearlyRevenueStatistics"]: @Model.SelectedYear
                            </h6>
                            <small class="text-white-50">
                                <i class="fas fa-chart-area mr-1"></i>
                                @L["Admin:Statistics:MonthlyRevenue"]
                            </small>
                        </div>
                        <div class="mt-3 mt-md-0">
                            <div class="d-inline-flex align-items-center">
                                <label class="text-white mr-2 mb-0 font-weight-bold">@L["Admin:Statistics:ChooseYear"]:</label>
                                <select id="yearSelect" class="form-control" onchange="changeYear()" style="width: auto;">
                                    @foreach (var year in Model.AvailableYears)
                                    {
                                        <option value="@year" selected="@(year == Model.SelectedYear ? "true" : "false")">@year</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="chart-loading">
                            <i class="fas fa-spinner fa-spin fa-2x text-primary"></i>
                            <p class="mt-2">@L["Admin:Statistics:Loading..."]</p>
                        </div>
                        <div class="chart-area" style="transition: opacity 0.3s ease;">
                            <canvas id="myAreaChart"></canvas>
                        </div>
                        <hr>
                        <div id="yearTotal" class="text-center text-muted">
                            @L["Admin:Statistics:TotalRevenueForYear"] @Model.SelectedYear: @Model.GetTotalForYear(Model.SelectedYear).ToString("N0") VND
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @await Component.InvokeAsync(typeof(ChatbotAdminPageWidgetViewComponent))
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                @Component.InvokeAsync(typeof(ChatbotAdminPageWidgetViewComponent))
            </div>
        </div>
    }
</div>

