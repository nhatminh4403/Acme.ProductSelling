@page "/account"
@model Acme.ProductSelling.Web.Pages.Account.IndexModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Account:ManageAccount"];
}

@section styles {
    <link href="~/css/global/user/account.css" rel="stylesheet" />
}
@section scripts {
    <script src="~/js/global/user/account.js"></script>
}

<div class="account-management-container">
    <div class="account-header modern-header">
        <div class="header-content">
            <h1><i class="fas fa-user-circle"></i> @L["Account:ManageAccount"]</h1>
            <p>@L["Account:ManageAccountDescription"]</p>
        </div>
        <div class="header-decoration"></div>
    </div>

    <div class="account-body modern-card">
        <div class="account-sidebar">
            <ul class="nav-menu">
                <li>
                    <a href="/account" class="nav-item active">
                        <i class="fas fa-user"></i>
                        <span>@L["Account:ProfileInformation"]</span>
                    </a>
                </li>
                <li>
                    <a href="/account/security" class="nav-item">
                        <i class="fas fa-lock"></i>
                        <span>@L["Account:Security"]</span>
                    </a>
                </li>
                <li>
                    <a href="/account/addresses" class="nav-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>@L["Account:Addresses"]</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="account-content">
            <div class="content-panel fade-in active">
                <form method="post" asp-page-handler="UpdateProfile" id="profile-form">
                    <div class="info-alert glass-alert">
                        <i class="fas fa-info-circle"></i>
                        <span>@L["Account:ProfileInfoDescription"]</span>
                    </div>

                    <div class="form-section">
                        <h3 class="section-title">
                            @L["Account:BasicInformation"]
                        </h3>
                        <div class="form-grid modern-grid">
                            <abp-input asp-for="@Model.ProfileInput.UserName" />
                            <abp-input asp-for="@Model.ProfileInput.Email" />
                            <abp-input asp-for="@Model.ProfileInput.Name" />
                            <abp-input asp-for="@Model.ProfileInput.Surname" />
                            <abp-input asp-for="@Model.ProfileInput.PhoneNumber" />
                            <div class="mb-3">
                                <label asp-for="ProfileInput.DateOfBirth" class="form-label"></label>
                                <input name="ProfileInput.DateOfBirth"
                                       id="ProfileInput_DateOfBirth"
                                       type="date"
                                       class="form-control"
                                       value="@(Model.ProfileInput.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                                <span asp-validation-for="ProfileInput.DateOfBirth" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">@L["Account:Gender"]</label>
                                <gender-select asp-for="@Model.ProfileInput.Gender" />
                                <span asp-validation-for="@Model.ProfileInput.Gender" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn-modern btn-secondary" onclick="resetForm('profile-form')">
                            <i class="fas fa-undo"></i> @L["Account:Reset"]
                        </button>
                        <button type="submit" class="btn-modern btn-primary" data-busy-text="@L["Account:Saving"]">
                            <i class="fas fa-save"></i> @L["Account:SaveChanges"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
