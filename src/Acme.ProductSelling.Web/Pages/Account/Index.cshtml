@page "/account"
@model Acme.ProductSelling.Web.Pages.Account.IndexModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Account:ManageYourAccount"];
}

@section styles {
    <link href="~/css/global/user/account.css" rel="stylesheet" />
}
@section scripts {
    <script src="~/js/global/user/account.js"></script>
}

<div class="acct-page-wrapper">
    <!-- Sidebar Navigation -->
    @await Component.InvokeAsync(typeof(AccountNavComponents), new AccountNavActive { NavActive = "info" })


    <!-- Main Content -->
    <main class="acct-main-content">
        <div class="acct-glass-card">
            <div class="acct-section-header">
                <h1 class="acct-section-title">@L["Account:Overview"]</h1>
                <p class="acct-section-subtitle">@L["Account:ManageAccountDescription"]</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="acct-alert-box acct-alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <div class="acct-info-grid">
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:UserName"]</div>
                    <div class="acct-info-value">@Model.CustomerProfile?.UserName</div>
                </div>
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:Email"]</div>
                    <div class="acct-info-value">@Model.CustomerProfile?.Email</div>
                </div>
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:Name"]</div>
                    <div class="acct-info-value">@Model.CustomerProfile?.Name @Model.CustomerProfile?.Surname</div>
                </div>
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:PhoneNumber"]</div>
                    <div class="acct-info-value">@(string.IsNullOrEmpty(Model.CustomerProfile?.PhoneNumber) ? "-" : Model.CustomerProfile.PhoneNumber)</div>
                </div>
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:DateOfBirth"]</div>
                    <div class="acct-info-value">@(Model.CustomerProfile?.DateOfBirth?.ToString("yyyy-MM-dd") ?? "-")</div>
                </div>
                <div class="acct-info-item">
                    <div class="acct-info-label">@L["Account:Gender"]</div>
                    <div class="acct-info-value">@Model.CustomerProfile?.Gender</div>
                </div>
                <div class="acct-info-item" style="grid-column: 1 / -1;">
                    <div class="acct-info-label">@L["Account:ShippingAddress"]</div>
                    <div class="acct-info-value">@(string.IsNullOrEmpty(Model.CustomerProfile?.ShippingAddress) ? "-" : Model.CustomerProfile.ShippingAddress)</div>
                </div>
            </div>
            
            <div class="acct-form-actions" style="margin-top: 2rem; border-top: none; padding-top: 0;">
                <a href="/account/editprofile" class="btn acct-btn-primary btn-primary" style="border-radius: 8px; padding: 0.75rem 1.5rem;">
                    <i class="fas fa-pen"></i> @L["Account:EditProfile"]
                </a>
            </div>
        </div>
    </main>
</div>
