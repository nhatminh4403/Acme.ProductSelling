@page "/account/addresses"
@model Acme.ProductSelling.Web.Pages.Account.AddressesModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Account:Addresses"];
}

@section styles {
    <link href="~/css/global/user/account.css" rel="stylesheet" />
    <style>
        /* ── Address table overflow ── */
        .addr-table-wrapper {
            max-height: calc(4 * 57px); /* 4 rows × approx row height */
            overflow-y: auto;
            border: 1px solid var(--bs-border-color);
            border-radius: .375rem;
        }

            .addr-table-wrapper table {
                margin-bottom: 0;
            }

            .addr-table-wrapper thead th {
                position: sticky;
                top: 0;
                z-index: 1;
                background-color: var(--bs-table-striped-bg, #f8f9fa);
            }

        /* ── Form section separators ── */
        .addr-form-section {
            margin-top: 1.5rem;
        }

        .addr-form-section-title {
            font-size: .85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--bs-secondary);
            margin-bottom: 1rem;
            padding-bottom: .4rem;
            border-bottom: 1px solid var(--bs-border-color);
        }

        /* Edit mode highlight */
        .addr-edit-banner {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .65rem 1rem;
            background: rgba(var(--bs-warning-rgb), .12);
            border: 1px solid rgba(var(--bs-warning-rgb), .35);
            border-radius: .375rem;
            margin-bottom: 1rem;
            font-size: .9rem;
        }
    </style>
}
@section scripts {
    <script src="~/js/global/user/account.js"></script>
}

<div class="acct-page-wrapper">
    <!-- Sidebar Navigation -->
    @await Component.InvokeAsync(typeof(AccountNavComponents) ,new AccountNavActive {NavActive = "addresses"})

    <!-- Main Content -->
    <main class="acct-main-content">
        <div class="acct-glass-card">

            <div class="acct-section-header">
                <h1 class="acct-section-title">@L["Account:Addresses"]</h1>
                <p class="acct-section-subtitle">@L["Account:AddressInfoDescription"]</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="acct-alert-box acct-alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }
            <div class="addr-table-wrapper">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@L["Account:Address"]</th>
                            <th class="text-center" style="width:90px;">@L["Account:Status"]</th>
                            <th class="text-center" style="width:110px;">@L["Account:Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.ShippingAddressList.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">
                                    <i class="fas fa-inbox me-1"></i> @L["Account:NoSavedAddresses"]
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var address in Model.ShippingAddressList)
                            {
                                var isEditing = Model.EditingAddressId == address.Id;
                                <tr class="@(isEditing ? "table-warning" : "")">
                                    <td>@address.FullAddress</td>
                                    <td class="text-center">
                                        @if (address.IsDefaultAddress)
                                        {
                                            <span class="badge bg-primary">@L["Account:Default"]</span>
                                        }
                                        else
                                        {
                                            <form asp-page-handler="SetDefault" method="post" asp-route-id="@address.Id" class="d-inline">
                                                <button type="submit" class="btn btn-outline-info text-black btn-sm">
                                                    @L["Account:SetAsDefault"]
                                                </button>
                                            </form>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a href="?editId=@address.Id"
                                               class="btn btn-outline-warning btn-sm @(isEditing ? "active" : "")"
                                               title="@L["Account:Edit"]">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <form asp-page-handler="DeleteAddress" method="post" asp-route-id="@address.Id" class="d-inline">
                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="@L["Account:Delete"]"
                                                    onclick="return confirm('@L["Account:ConfirmDelete"]')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.EditingAddressId.HasValue)
            {
                <div class="addr-form-section">
                    <div class="addr-edit-banner">
                        <i class="fas fa-pencil-alt text-warning"></i>
                        <span>@L["Account:EditingAddress"]</span>
                        <a href="/account/addresses" class="ms-auto btn btn-sm btn-outline-secondary">
                            <i class="fas fa-times"></i> @L["Account:Cancel"]
                        </a>
                    </div>

                    <p class="addr-form-section-title">@L["Account:UpdateAddress"]</p>

                    <form method="post" asp-page-handler="UpdateAddress" asp-route-id="@Model.EditingAddressId">
                        <div class="acct-info-grid">
                            <div class="acct-form-row" style="grid-column: 1 / -1;">
                                <abp-input asp-for="@Model.UpdateAddressInput.FullAddress" />
                            </div>
                        </div>
                        <div class="acct-form-actions">
                            <a href="/account/addresses" class="btn btn-secondary">
                                <i class="fas fa-times"></i> @L["Account:Cancel"]
                            </a>
                            <button type="submit" class="btn btn-warning" data-busy-text="@L["Account:Saving"]">
                                <i class="fas fa-save"></i> @L["Account:SaveChanges"]
                            </button>
                        </div>
                    </form>
                </div>
            }

            <div class="addr-form-section">
                <p class="addr-form-section-title">@L["Account:AddNewAddress"]</p>

                <form method="post" asp-page-handler="AddNewAddress">
                    <div class="acct-info-grid">
                        <div class="acct-form-row" style="grid-column: 1 / -1;">
                            <abp-input asp-for="@Model.NewShippingAddressInput.FullAddress" />
                        </div>
                    </div>
                    <div class="acct-form-actions">
                        <button type="reset" class="btn btn-secondary">
                            <i class="fas fa-undo"></i> @L["Account:Reset"]
                        </button>
                        <button type="submit" class="btn btn-primary" data-busy-text="@L["Account:Saving"]">
                            <i class="fas fa-plus"></i> @L["Account:AddAddress"]
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </main>
</div>