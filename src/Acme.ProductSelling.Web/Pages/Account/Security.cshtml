@page "/account/security"
@model Acme.ProductSelling.Web.Pages.Account.SecurityModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = L["Account:Security"];
}

@section styles {
    <link href="~/css/global/user/account.css" rel="stylesheet" />
}
@section scripts {
    <script src="~/js/global/user/account.js"></script>
}

<div class="acct-page-wrapper">
    <!-- Sidebar Navigation -->
    @await Component.InvokeAsync(typeof(AccountNavComponents), new AccountNavActive { NavActive = "password" })


    <!-- Main Content -->
    <main class="acct-main-content">
        <div class="acct-glass-card">
            <div class="acct-section-header">
                <h1 class="acct-section-title">@L["Account:Security"]</h1>
                <p class="acct-section-subtitle">@L["Account:SecurityDescription"]</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="acct-alert-box acct-alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post">
                <div class="acct-info-grid">
                    <div class="acct-form-row">
                        <abp-input asp-for="PasswordInput.CurrentPassword" />
                    </div>
                    <div class="acct-form-row" style="grid-column: 1 / -1;">
                        <abp-input asp-for="PasswordInput.NewPassword" />
                        <div class="acct-pwd-indicator">
                            <div class="acct-pwd-bars">
                                <div class="acct-pwd-bar"></div>
                                <div class="acct-pwd-bar"></div>
                                <div class="acct-pwd-bar"></div>
                            </div>
                            <span class="acct-pwd-text"></span>
                        </div>
                    </div>
                    <div class="acct-form-row">
                        <abp-input asp-for="PasswordInput.ConfirmPassword" />
                    </div>
                </div>

                <div class="acct-form-actions">
                    <button type="reset" class="btn btn-secondary">
                        <i class="fas fa-undo"></i> @L["Account:Reset"]
                    </button>
                    <button type="submit" class="btn btn-primary" data-busy-text="@L["Account:Changing"]">
                        <i class="fas fa-lock"></i> @L["Account:ChangePassword"]
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>
