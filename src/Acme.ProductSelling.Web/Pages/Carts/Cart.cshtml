@page "/cart"
@model Acme.ProductSelling.Web.Pages.Carts.CartModel

@{
    ViewData["Title"] = L["Cart:ShoppingCart"];
    Layout = "/Views/Shared/_Layout.cshtml";
}
@section scripts {
    <abp-script src ="/Pages/Carts/Index.js" />
}
@section styles {
   <link href="~/css/global/cart/cart.css" rel="stylesheet" />
}
<div class="container mt-4 mb-5">
    <h1>@L["Cart:ShoppingCart"]</h1>


    @if (Model.Cart != null && Model.Cart.CartItems.Any())
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th scope="Column" style="width: 35%;">@L["Cart:Product"]</th>
                        <th scope="Column" style="width: 15%;" class="text-end">@L["Cart:Price"]</th>
                        <th scope="Column" style="width: 15%;" class="text-center">@L["Cart:Quantity"]</th>
                        <th scope="Column" style="width: 15%;" class="text-end">@L["Cart:Total"]</th>
                        <th scope="Column" style="width: 10%;" class="text-center">@L["Cart:Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Cart.CartItems)
                    {
                        <tr>

                            <td>
                                <a asp-page="/Products/ProductDetail"
                                   asp-route-slug="@item.ProductUrlSlug" class="text-dark text-decoration-none fw-bold">
                                    @item.ProductName
                                </a>
                                @* Có thể thêm các thông tin khác như thuộc tính sản phẩm nếu cần *@
                            </td>
                            <td class="text-end">@item.ProductPrice.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                            <td class="text-center">
                                <form method="post" asp-page-handler="UpdateItem" class="d-inline">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <div class="input-group input-group-sm" style="width: 130px; margin: 0 auto;">
                                        <button type="button" class="btn btn-outline-secondary btn-decrease"
                                                data-item-id="@item.Id"
                                                data-current-quantity="@item.Quantity">
                                            <i class="fas fa-minus"></i>
                                        </button>
                                        <input type="number" name="quantity"
                                               class="form-control text-center quantity-input"
                                               value="@item.Quantity"
                                               min="1"
                                               max="100"
                                               data-item-id="@item.Id" />
                                        <button type="button" class="btn btn-outline-secondary btn-increase"
                                                data-item-id="@item.Id"
                                                data-current-quantity="@item.Quantity">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </div>
                                </form>
                            </td>
                            <td class="text-end fw-bold">@item.LineTotal.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</td>
                            <td class="text-end align-middle">
                                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-item"
                                        data-item-id="@item.Id"
                                        data-product-name="@item.ProductName">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6 offset-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@L["Cart:Summary"]</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @L["Cart:Subtotal"]
                                <span>@Model.Cart.TotalPrice.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center fw-bold fs-5">
                                @L["Cart:Total"]
                                <span>@Model.Cart.TotalPrice.ToString("C0", CultureInfo.GetCultureInfo("vi-VN"))</span> @* Tạm thời chỉ có Subtotal *@
                            </li>
                        </ul>
                        <div class="d-grid gap-2 mt-3">
                            <a asp-page="/Orders/Checkout" class="btn btn-primary btn-lg">@L["Cart:ProceedToCheckout"]</a>
                            <a asp-page="/Index" class="btn btn-outline-secondary">@L["ContinueShopping"]</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <p>@L["Cart:YourCartIsEmpty"]</p>
            <a asp-page="/Index" class="btn btn-primary">@L["StartShopping"]</a>
        </div>
    }
</div>