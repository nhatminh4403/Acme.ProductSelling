{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "@microsoft/signalr@10.0.0",
      "provider": "jsdelivr",
      "destination": "wwwroot/lib/microsoft/js/signalr/"
    },
    {
      "library": "summernote@0.9.1",
      "destination": "wwwroot/lib/summernote/"
    },
    {
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/lib/bootstrap-icons/"
    },
    {
      "library": "bootstrap-iconpicker@1.10.0",
      "destination": "wwwroot/lib/bootstrap-iconpicker/"
    },
    {
      "library": "bootstrap@5.3.8",
      "destination": "wwwroot/lib/bootstrap/"
    },
    {
      "library": "fontawesome-iconpicker@3.2.0",
      "destination": "wwwroot/lib/fontawesome-iconpicker/"
    },
    {
      "library": "font-awesome@7.0.1",
      "destination": "wwwroot/lib/font-awesome/"
    },
    {
      "library": "marked@16.3.0",
      "destination": "wwwroot/lib/marked/",
      "files": [
        "lib/marked.umd.min.js",
        "lib/marked.esm.min.js"
      ]
    }
  ]
}